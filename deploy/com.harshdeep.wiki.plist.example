<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.harshdeep.wiki</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/harshdeepsingh/Build/wiki/.venv/bin/uvicorn</string>
        <string>app.main:app</string>
        <string>--host</string>
        <string>127.0.0.1</string>
        <string>--port</string>
        <string>8765</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/harshdeepsingh/Build/wiki</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PYTHONPATH</key>
        <string>/Users/harshdeepsingh/Build/wiki</string>
        <key>CONTENT_DIR</key>
        <string>/Users/user/PATH_TO_VAULT</string>
        <key>COOKIE_SECURE</key>
        <string>1</string>
        <key>NKR_CMD</key>
        <string>/Users/harshdeepsingh/Build/nkr/.venv/bin/nkr</string>
        <key>NKR_CWD</key>
        <string>/Users/harshdeepsingh/Build/nkr</string>
        <!-- REPLACE the two values below before loading -->
        <key>WIKI_PASSWORD</key>
        <string>REPLACE_ME</string>
        <key>SECRET_KEY</key>
        <string>REPLACE_ME_32_BYTES_URLSAFE</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/harshdeepsingh/Library/Logs/wiki.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/harshdeepsingh/Library/Logs/wiki.err.log</string>
</dict>
</plist>
